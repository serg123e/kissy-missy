{
  "name": "kissy-missy-castle",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "PrisonSpawn": {
        "$className": "Part",
        "$properties": {
          "Size": [4, 1, 4],
          "Position": [0, 1, 0],
          "Anchored": true,
          "Transparency": 0.5
        }
      },
      "PrisonExit": {
        "$className": "Part",
        "$properties": {
          "Size": [4, 1, 4],
          "Position": [10, 1, 0],
          "Anchored": true,
          "Transparency": 0.5
        }
      },
      "PrisonDoor": {
        "$className": "Part",
        "$properties": {
          "Size": [6, 8, 1],
          "Position": [5, 5, 0],
          "Anchored": true
        }
      },
      "Treadmills": {
        "$className": "Folder",
        "Treadmill1": {
          "$className": "Part",
          "$properties": {
            "Size": [8, 1, 4],
            "Position": [30, 1, 30],
            "Anchored": true
          }
        },
        "Treadmill2": {
          "$className": "Part",
          "$properties": {
            "Size": [8, 1, 4],
            "Position": [30, 1, 38],
            "Anchored": true
          }
        },
        "Treadmill3": {
          "$className": "Part",
          "$properties": {
            "Size": [8, 1, 4],
            "Position": [30, 1, 46],
            "Anchored": true
          }
        },
        "Treadmill4": {
          "$className": "Part",
          "$properties": {
            "Size": [8, 1, 4],
            "Position": [30, 1, 54],
            "Anchored": true
          }
        }
      },
      "KissySpawn": {
        "$className": "Part",
        "$properties": {
          "Size": [4, 1, 4],
          "Position": [0, 1, -20],
          "Anchored": true,
          "Transparency": 0.5
        }
      }
    },
    "ServerStorage": {
      "$className": "ServerStorage"
    },
    "Lighting": {
      "$properties": {
        "Ambient": [0, 0, 0],
        "Brightness": 2,
        "GlobalShadows": true,
        "Technology": "ShadowMap"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}